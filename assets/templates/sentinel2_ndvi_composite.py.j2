"""{{ script_name }}

Create a Sentinel-2 NDVI composite and export it.
Generated by gee-agent-skill template sentinel2_ndvi_composite v0.1.0.
"""

from __future__ import annotations

import logging
import sys

import ee

LOG = logging.getLogger("gee_skill.sentinel2_ndvi")

DATASET_ID = "{{ dataset_id }}"
START_DATE = "{{ date_start }}"
END_DATE = "{{ date_end }}"
AOI_ASSET = "{{ aoi_asset }}"
SCALE = {{ scale }}
CRS = "{{ crs }}"
TILE_SCALE = {{ tile_scale | default(4) }}
EXPORT_DESCRIPTION = "{{ export_description }}"
DRIVE_FOLDER = "{{ drive_folder }}"
FILE_PREFIX = "{{ file_prefix | default(export_description) }}"
MAX_PIXELS = {{ max_pixels | default(10000000000000) }}


def mask_sentinel2_scl(image: ee.Image) -> ee.Image:
    scl = image.select("SCL")
    valid = (
        scl.neq(0)
        .And(scl.neq(1))
        .And(scl.neq(3))
        .And(scl.neq(7))
        .And(scl.neq(8))
        .And(scl.neq(9))
        .And(scl.neq(10))
        .And(scl.neq(11))
    )
    return image.updateMask(valid)


def add_ndvi(image: ee.Image) -> ee.Image:
    return image.addBands(image.normalizedDifference(["B8", "B4"]).rename("NDVI"))


def build_composite() -> ee.Image:
    aoi = ee.FeatureCollection(AOI_ASSET).geometry()
    collection = (
        ee.ImageCollection(DATASET_ID)
        .filterDate(START_DATE, END_DATE)
        .filterBounds(aoi)
        .filter(ee.Filter.lt("CLOUDY_PIXEL_PERCENTAGE", {{ cloudy_pixel_percentage | default(80) }}))
        .map(mask_sentinel2_scl)
        .map(add_ndvi)
    )
    return (
        collection.select("NDVI")
        .median()
        .rename("NDVI")
        .clip(aoi)
        .set("date_start", START_DATE)
        .set("date_end", END_DATE)
        .set("dataset_id", DATASET_ID)
    )


def create_export_task() -> ee.batch.Task:
    aoi = ee.FeatureCollection(AOI_ASSET).geometry()
    task = ee.batch.Export.image.toDrive(
        image=build_composite(),
        description=EXPORT_DESCRIPTION,
        folder=DRIVE_FOLDER,
        fileNamePrefix=FILE_PREFIX,
        region=aoi,
        scale=SCALE,
        crs=CRS,
        maxPixels=MAX_PIXELS,
    )
    return task


def main() -> int:
    logging.basicConfig(level=logging.INFO, format="%(levelname)s %(message)s")
    try:
        task = create_export_task()
        task.start()
        LOG.info("Started export task: %s", EXPORT_DESCRIPTION)
        return 0
    except Exception as exc:
        LOG.exception("Failed to export Sentinel-2 NDVI composite.")
        print(f"ERROR: {exc}", file=sys.stderr)
        return 1


if __name__ == "__main__":
    raise SystemExit(main())

