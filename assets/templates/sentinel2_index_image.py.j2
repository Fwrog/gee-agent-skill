"""{{ script_name }}

Create a Sentinel-2 optical index image and export it as GeoTIFF.
Generated by gee-agent-skill template sentinel2_index_image v0.1.0.
"""

from __future__ import annotations

import logging
import sys

import ee

LOG = logging.getLogger("gee_skill.sentinel2_index_image")

DATASET_ID = "{{ dataset_id }}"
START_DATE = "{{ date_start }}"
END_DATE = "{{ date_end }}"
AOI_ASSET = "{{ aoi_asset }}"
INDEX_NAME = "{{ index_name }}"
INDEX_BANDS = [{% for band in index_bands %}"{{ band }}"{% if not loop.last %}, {% endif %}{% endfor %}]
SCALE = {{ scale }}
CRS = "{{ crs }}"
TILE_SCALE = {{ tile_scale | default(4) }}
CLOUDY_PIXEL_PERCENTAGE = {{ cloudy_pixel_percentage | default(80) }}
EXPORT_DESCRIPTION = "{{ export_description }}"
DRIVE_FOLDER = "{{ drive_folder }}"
FILE_PREFIX = "{{ file_prefix | default(export_description) }}"
MAX_PIXELS = {{ max_pixels | default(10000000000000) }}


def mask_sentinel2_scl(image: ee.Image) -> ee.Image:
    scl = image.select("SCL")
    valid = (
        scl.neq(0)
        .And(scl.neq(1))
        .And(scl.neq(3))
        .And(scl.neq(7))
        .And(scl.neq(8))
        .And(scl.neq(9))
        .And(scl.neq(10))
        .And(scl.neq(11))
    )
    return image.updateMask(valid)


def add_index(image: ee.Image) -> ee.Image:
    {% if index_expression is defined and index_expression %}
    index = image.expression(
        "{{ index_expression }}",
        {
            {% for name, band in expression_bands.items() %}
            "{{ name }}": image.select("{{ band }}"){% if not loop.last %},{% endif %}
            {% endfor %}
        },
    ).rename(INDEX_NAME)
    return image.addBands(index)
    {% else %}
    return image.addBands(image.normalizedDifference(INDEX_BANDS).rename(INDEX_NAME))
    {% endif %}


def build_index_image() -> ee.Image:
    aoi = ee.FeatureCollection(AOI_ASSET).geometry()
    collection = (
        ee.ImageCollection(DATASET_ID)
        .filterDate(START_DATE, END_DATE)
        .filterBounds(aoi)
        .filter(ee.Filter.lt("CLOUDY_PIXEL_PERCENTAGE", CLOUDY_PIXEL_PERCENTAGE))
        .map(mask_sentinel2_scl)
        .map(add_index)
    )
    return (
        collection.select(INDEX_NAME)
        .median()
        .rename(INDEX_NAME)
        .clip(aoi)
        .set("date_start", START_DATE)
        .set("date_end", END_DATE)
        .set("dataset_id", DATASET_ID)
        .set("index_name", INDEX_NAME)
    )


def create_export_task() -> ee.batch.Task:
    aoi = ee.FeatureCollection(AOI_ASSET).geometry()
    return ee.batch.Export.image.toDrive(
        image=build_index_image(),
        description=EXPORT_DESCRIPTION,
        folder=DRIVE_FOLDER,
        fileNamePrefix=FILE_PREFIX,
        region=aoi,
        scale=SCALE,
        crs=CRS,
        fileFormat="GeoTIFF",
        maxPixels=MAX_PIXELS,
    )


def main() -> int:
    logging.basicConfig(level=logging.INFO, format="%(levelname)s %(message)s")
    try:
        task = create_export_task()
        task.start()
        LOG.info("Started Sentinel-2 %s image export: %s", INDEX_NAME, EXPORT_DESCRIPTION)
        return 0
    except Exception as exc:
        LOG.exception("Failed to export Sentinel-2 optical index image.")
        print(f"ERROR: {exc}", file=sys.stderr)
        return 1


if __name__ == "__main__":
    raise SystemExit(main())
