"""{{ script_name }}

Compute zonal statistics for a prepared Earth Engine image expression.
Generated by gee-agent-skill template zonal_statistics v0.1.0.
"""

from __future__ import annotations

import logging
import sys

import ee

LOG = logging.getLogger("gee_skill.zonal_statistics")

START_DATE = "{{ date_start }}"
END_DATE = "{{ date_end }}"
ZONES_ASSET = "{{ zones_asset }}"
SCALE = {{ scale }}
CRS = "{{ crs }}"
TILE_SCALE = {{ tile_scale | default(4) }}
EXPORT_DESCRIPTION = "{{ export_description }}"
DRIVE_FOLDER = "{{ drive_folder }}"
FILE_PREFIX = "{{ file_prefix | default(export_description) }}"


def build_image() -> ee.Image:
    image = {{ image_expression }}
    return image.set("date_start", START_DATE).set("date_end", END_DATE)


def build_statistics() -> ee.FeatureCollection:
    zones = ee.FeatureCollection(ZONES_ASSET)
    image = build_image()
    return image.reduceRegions(
        collection=zones,
        reducer=ee.Reducer.{{ reducer | default('mean') }}(),
        scale=SCALE,
        crs=CRS,
        tileScale=TILE_SCALE,
    )


def create_export_task() -> ee.batch.Task:
    return ee.batch.Export.table.toDrive(
        collection=build_statistics(),
        description=EXPORT_DESCRIPTION,
        folder=DRIVE_FOLDER,
        fileNamePrefix=FILE_PREFIX,
        fileFormat="{{ file_format | default('CSV') }}",
    )


def main() -> int:
    logging.basicConfig(level=logging.INFO, format="%(levelname)s %(message)s")
    try:
        task = create_export_task()
        task.start()
        LOG.info("Started export task: %s", EXPORT_DESCRIPTION)
        return 0
    except Exception as exc:
        LOG.exception("Failed to export zonal statistics.")
        print(f"ERROR: {exc}", file=sys.stderr)
        return 1


if __name__ == "__main__":
    raise SystemExit(main())

