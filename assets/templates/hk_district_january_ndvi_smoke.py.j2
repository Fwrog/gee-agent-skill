"""{{ script_name }}

Small live smoke test: one Hong Kong district, one month, Sentinel-2 NDVI mean CSV export.
Generated by gee-agent-skill template hk_district_january_ndvi_smoke v0.3.0.
"""

from __future__ import annotations

import json
import logging
import sys

import ee

from geeskill.hk_ndvi_preflight import (
    HKNDVIPreflightConfig,
    load_boundary_feature_collection,
    load_boundary_geojson,
    resolve_district_name,
    run_hk_ndvi_preflight,
)

LOG = logging.getLogger("gee_skill.hk_january_ndvi_smoke")

YEAR = {{ year | default(2024) }}
SMOKE_MONTH = {{ smoke_month }}
SMOKE_REGION = "{{ smoke_region }}"
START_DATE = "{{ year | default(2024) }}-{{ "%02d"|format(smoke_month) }}-01"
END_DATE = "{% if smoke_month == 12 %}{{ (year | default(2024)) + 1 }}-01-01{% else %}{{ year | default(2024) }}-{{ "%02d"|format(smoke_month + 1) }}-01{% endif %}"
DATASET_ID = "{{ dataset_id | default('COPERNICUS/S2_SR_HARMONIZED') }}"
BOUNDARY_GEOJSON = "{{ boundary_geojson | default('references/boundaries/hk_18_districts.geojson') }}"
DISTRICT_PROPERTY = "{{ district_property | default('District') }}"
SCALE = {{ scale | default(10) }}
CRS = "{{ crs | default('EPSG:4326') }}"
TILE_SCALE = {{ tile_scale | default(4) }}
CLOUDY_PIXEL_PERCENTAGE = {{ cloudy_pixel_percentage | default(80) }}
EXPORT_DESCRIPTION = "{{ export_description }}"
DRIVE_FOLDER = "{{ drive_folder }}"
FILE_PREFIX = "{{ file_prefix | default(export_description) }}"


def mask_sentinel2_scl(image: ee.Image) -> ee.Image:
    scl = image.select("SCL")
    valid = (
        scl.neq(0)
        .And(scl.neq(1))
        .And(scl.neq(3))
        .And(scl.neq(7))
        .And(scl.neq(8))
        .And(scl.neq(9))
        .And(scl.neq(10))
        .And(scl.neq(11))
    )
    return image.updateMask(valid)


def add_ndvi(image: ee.Image) -> ee.Image:
    ndvi = image.normalizedDifference(["B8", "B4"]).rename("NDVI")
    return image.addBands(ndvi)


def canonical_district_name(district_name: str) -> str:
    data = load_boundary_geojson(BOUNDARY_GEOJSON)
    names = sorted(
        feature.get("properties", {}).get(DISTRICT_PROPERTY)
        for feature in data.get("features", [])
        if feature.get("properties", {}).get(DISTRICT_PROPERTY)
    )
    return resolve_district_name(district_name, names) or district_name


def build_districts() -> ee.FeatureCollection:
    return load_boundary_feature_collection(ee, BOUNDARY_GEOJSON)


def build_region(district_name: str | None = None) -> ee.FeatureCollection:
    districts = build_districts()
    if not district_name:
        return districts
    canonical = canonical_district_name(district_name)
    return districts.filter(ee.Filter.eq(DISTRICT_PROPERTY, canonical))


def build_s2_collection(month: int, district_name: str | None = None) -> ee.ImageCollection:
    region = build_region(district_name)
    aoi = region.geometry()
    start = ee.Date(START_DATE)
    end = ee.Date(END_DATE)
    return (
        ee.ImageCollection(DATASET_ID)
        .filterDate(start, end)
        .filterBounds(aoi)
        .filter(ee.Filter.lt("CLOUDY_PIXEL_PERCENTAGE", CLOUDY_PIXEL_PERCENTAGE))
    )


def build_monthly_ndvi(month: int, district_name: str | None = None) -> ee.Image:
    collection = build_s2_collection(month, district_name).map(mask_sentinel2_scl).map(add_ndvi)
    return collection.select("NDVI").mean().rename("mean_ndvi")


def preflight_month(month: int, district_name: str | None = None) -> dict:
    return run_hk_ndvi_preflight(
        HKNDVIPreflightConfig(
            project=None,
            year=YEAR,
            month=month,
            district=district_name,
            dataset_id=DATASET_ID,
            boundary_geojson=BOUNDARY_GEOJSON,
            district_property=DISTRICT_PROPERTY,
            scale=SCALE,
            crs=CRS,
            cloudy_pixel_percentage=CLOUDY_PIXEL_PERCENTAGE,
            tile_scale=TILE_SCALE,
        )
    )


def build_statistics() -> ee.FeatureCollection:
    report = preflight_month(SMOKE_MONTH, SMOKE_REGION)
    if not report.get("ok"):
        raise RuntimeError("Preflight failed before export: " + json.dumps(report.get("critical_error"), ensure_ascii=False))
    canonical_region = report["checks"]["selected_district"]["selected_district_name"]
    region = build_region(canonical_region)
    start = ee.Date(START_DATE)
    end = ee.Date(END_DATE)
    collection = build_s2_collection(SMOKE_MONTH, canonical_region)
    monthly_ndvi = build_monthly_ndvi(SMOKE_MONTH, canonical_region)
    stats = monthly_ndvi.reduceRegions(
        collection=region,
        reducer=ee.Reducer.mean(),
        scale=SCALE,
        crs=CRS,
        tileScale=TILE_SCALE,
    )

    def annotate(feature):
        return feature.set(
            {
                "district_name": feature.get(DISTRICT_PROPERTY),
                "year": YEAR,
                "month": SMOKE_MONTH,
                "date_start": start.format("YYYY-MM-dd"),
                "date_end": end.format("YYYY-MM-dd"),
                "dataset_id": DATASET_ID,
                "scale_m": SCALE,
                "crs": CRS,
                "image_count": collection.size(),
            }
        )

    return stats.map(annotate)


def create_export_task() -> ee.batch.Task:
    return ee.batch.Export.table.toDrive(
        collection=build_statistics(),
        description=EXPORT_DESCRIPTION,
        folder=DRIVE_FOLDER,
        fileNamePrefix=FILE_PREFIX,
        fileFormat="CSV",
        selectors=[
            "district_name",
            DISTRICT_PROPERTY,
            "year",
            "month",
            "date_start",
            "date_end",
            "mean",
            "image_count",
            "dataset_id",
            "scale_m",
            "crs",
        ],
    )


def main() -> int:
    logging.basicConfig(level=logging.INFO, format="%(levelname)s %(message)s")
    try:
        task = create_export_task()
        task.start()
        LOG.info("Started smoke export task: %s", EXPORT_DESCRIPTION)
        return 0
    except Exception as exc:
        LOG.exception("Failed to start live smoke export.")
        print(f"ERROR: {exc}", file=sys.stderr)
        return 1


if __name__ == "__main__":
    raise SystemExit(main())
