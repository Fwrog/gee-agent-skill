"""{{ script_name }}

January 2024 Hong Kong NDVI diagnostics by Dynamic World land-cover class.
Generated by gee-agent-skill template hk_january_2024_ndvi_by_landcover_csv v0.2.

Boundary data defines where statistics are computed. Land-cover data defines
masks and interpretation strata only.
"""

from __future__ import annotations

import logging
import sys

import ee

from geeskill.hk_ndvi_preflight import load_boundary_feature_collection

LOG = logging.getLogger("gee_skill.hk_january_2024_ndvi_by_landcover_csv")

YEAR = {{ year }}
MONTH = {{ month }}
DATE_START = "{{ date_start }}"
DATE_END = "{{ date_end }}"
AOI_NAME = "{{ aoi_name }}"
AOI_SOURCE = "{{ aoi_source }}"
BOUNDARY_GEOJSON = "{{ boundary_geojson }}"
DATASET_ID = "{{ dataset_id }}"
LANDCOVER_DATASET_ID = "{{ landcover_dataset_id }}"
LANDCOVER_STRATEGY = "{{ landcover_strategy }}"
DYNAMIC_WORLD_PROBABILITY_THRESHOLD = {{ dynamic_world_probability_threshold }}
SCALE = {{ scale }}
CRS = "{{ crs }}"
TILE_SCALE = {{ tile_scale }}
CLOUDY_PIXEL_PERCENTAGE = {{ cloudy_pixel_percentage }}
MAX_PIXELS = {{ max_pixels }}
EXPORT_DESCRIPTION = "{{ export_description }}"
DRIVE_FOLDER = "{{ drive_folder }}"
FILE_PREFIX = "{{ file_prefix }}"
PREFLIGHT_REQUIRED_BEFORE_EXPORT = True

DYNAMIC_WORLD_PROBABILITY_BANDS = [
    "water",
    "trees",
    "grass",
    "flooded_vegetation",
    "crops",
    "shrub_and_scrub",
    "built",
    "bare",
    "snow_and_ice",
]

EXPORT_SELECTORS = [
    "aoi_name",
    "year",
    "month",
    "date_start",
    "date_end",
    "dataset_id",
    "landcover_dataset_id",
    "landcover_strategy",
    "scale_m",
    "crs",
    "all_surface_mean_ndvi",
    "non_water_mean_ndvi",
    "land_only_mean_ndvi",
    "vegetation_mean_ndvi",
    "trees_mean_ndvi",
    "grass_mean_ndvi",
    "shrub_and_scrub_mean_ndvi",
    "built_mean_ndvi",
    "bare_mean_ndvi",
    "water_fraction",
    "built_fraction",
    "vegetation_fraction",
    "trees_fraction",
    "grass_fraction",
    "s2_image_count_before_cloud_filter",
    "s2_image_count_after_cloud_filter",
    "dynamic_world_image_count",
    "dynamic_world_probability_threshold",
    "export_description",
]


def build_hong_kong_aoi() -> ee.FeatureCollection:
    return load_boundary_feature_collection(ee, BOUNDARY_GEOJSON)


def build_s2_collection_before_cloud_filter(start: ee.Date, end: ee.Date, aoi: ee.Geometry) -> ee.ImageCollection:
    return ee.ImageCollection(DATASET_ID).filterDate(start, end).filterBounds(aoi)


def build_s2_collection(start: ee.Date, end: ee.Date, aoi: ee.Geometry) -> ee.ImageCollection:
    return (
        build_s2_collection_before_cloud_filter(start, end, aoi)
        .filter(ee.Filter.lt("CLOUDY_PIXEL_PERCENTAGE", CLOUDY_PIXEL_PERCENTAGE))
    )


def mask_sentinel2_scl(image: ee.Image) -> ee.Image:
    scl = image.select("SCL")
    valid = (
        scl.neq(0)
        .And(scl.neq(1))
        .And(scl.neq(3))
        .And(scl.neq(7))
        .And(scl.neq(8))
        .And(scl.neq(9))
        .And(scl.neq(10))
        .And(scl.neq(11))
    )
    return image.updateMask(valid)


def add_ndvi(image: ee.Image) -> ee.Image:
    ndvi = image.normalizedDifference(["B8", "B4"]).rename("NDVI")
    return image.addBands(ndvi)


def build_monthly_ndvi(start: ee.Date, end: ee.Date, aoi: ee.Geometry) -> ee.Image:
    collection = build_s2_collection(start, end, aoi).map(mask_sentinel2_scl).map(add_ndvi)
    return collection.select("NDVI").mean().rename("NDVI")


def build_dynamic_world_collection(start: ee.Date, end: ee.Date, aoi: ee.Geometry) -> ee.ImageCollection:
    return ee.ImageCollection(LANDCOVER_DATASET_ID).filterDate(start, end).filterBounds(aoi)


def build_dynamic_world_composite(start: ee.Date, end: ee.Date, aoi: ee.Geometry) -> ee.Image:
    collection = build_dynamic_world_collection(start, end, aoi)
    probabilities = collection.select(DYNAMIC_WORLD_PROBABILITY_BANDS).mean()
    labels = collection.select("label").mode().rename("label")
    return probabilities.addBands(labels)


def build_landcover_masks(landcover: ee.Image) -> dict[str, ee.Image]:
    water = landcover.select("water").gte(DYNAMIC_WORLD_PROBABILITY_THRESHOLD)
    trees = landcover.select("trees").gte(DYNAMIC_WORLD_PROBABILITY_THRESHOLD)
    grass = landcover.select("grass").gte(DYNAMIC_WORLD_PROBABILITY_THRESHOLD)
    flooded = landcover.select("flooded_vegetation").gte(DYNAMIC_WORLD_PROBABILITY_THRESHOLD)
    crops = landcover.select("crops").gte(DYNAMIC_WORLD_PROBABILITY_THRESHOLD)
    shrub = landcover.select("shrub_and_scrub").gte(DYNAMIC_WORLD_PROBABILITY_THRESHOLD)
    vegetation = trees.Or(grass).Or(flooded).Or(crops).Or(shrub)
    return {
        "water": water.rename("class_mask"),
        "non_water": water.Not().rename("class_mask"),
        "land_only": water.Not().rename("class_mask"),
        "vegetation": vegetation.rename("class_mask"),
        "trees": trees.rename("class_mask"),
        "grass": grass.rename("class_mask"),
        "shrub_and_scrub": shrub.rename("class_mask"),
        "built": landcover.select("built").gte(DYNAMIC_WORLD_PROBABILITY_THRESHOLD).rename("class_mask"),
        "bare": landcover.select("bare").gte(DYNAMIC_WORLD_PROBABILITY_THRESHOLD).rename("class_mask"),
    }


def masked_mean_ndvi(ndvi: ee.Image, mask: ee.Image | None, aoi: ee.Geometry):
    image = ndvi if mask is None else ndvi.updateMask(mask)
    return image.reduceRegion(
        reducer=ee.Reducer.mean(),
        geometry=aoi,
        scale=SCALE,
        crs=CRS,
        bestEffort=True,
        maxPixels=MAX_PIXELS,
        tileScale=TILE_SCALE,
    ).get("NDVI")


def class_fraction(mask: ee.Image, aoi: ee.Geometry):
    return mask.unmask(0).reduceRegion(
        reducer=ee.Reducer.mean(),
        geometry=aoi,
        scale=SCALE,
        crs=CRS,
        bestEffort=True,
        maxPixels=MAX_PIXELS,
        tileScale=TILE_SCALE,
    ).get("class_mask")


def build_summary_feature() -> ee.Feature:
    districts = build_hong_kong_aoi()
    aoi = districts.geometry()
    start = ee.Date(DATE_START)
    end = start.advance(1, "month")

    s2_before_cloud = build_s2_collection_before_cloud_filter(start, end, aoi)
    s2_after_cloud = build_s2_collection(start, end, aoi)
    ndvi = build_monthly_ndvi(start, end, aoi)
    dynamic_world = build_dynamic_world_collection(start, end, aoi)
    landcover = build_dynamic_world_composite(start, end, aoi)
    masks = build_landcover_masks(landcover)

    return ee.Feature(
        None,
        {
            "aoi_name": AOI_NAME,
            "year": YEAR,
            "month": MONTH,
            "date_start": DATE_START,
            "date_end": DATE_END,
            "dataset_id": DATASET_ID,
            "landcover_dataset_id": LANDCOVER_DATASET_ID,
            "landcover_strategy": LANDCOVER_STRATEGY,
            "scale_m": SCALE,
            "crs": CRS,
            "all_surface_mean_ndvi": masked_mean_ndvi(ndvi, None, aoi),
            "non_water_mean_ndvi": masked_mean_ndvi(ndvi, masks["non_water"], aoi),
            "land_only_mean_ndvi": masked_mean_ndvi(ndvi, masks["land_only"], aoi),
            "vegetation_mean_ndvi": masked_mean_ndvi(ndvi, masks["vegetation"], aoi),
            "trees_mean_ndvi": masked_mean_ndvi(ndvi, masks["trees"], aoi),
            "grass_mean_ndvi": masked_mean_ndvi(ndvi, masks["grass"], aoi),
            "shrub_and_scrub_mean_ndvi": masked_mean_ndvi(ndvi, masks["shrub_and_scrub"], aoi),
            "built_mean_ndvi": masked_mean_ndvi(ndvi, masks["built"], aoi),
            "bare_mean_ndvi": masked_mean_ndvi(ndvi, masks["bare"], aoi),
            "water_fraction": class_fraction(masks["water"], aoi),
            "built_fraction": class_fraction(masks["built"], aoi),
            "vegetation_fraction": class_fraction(masks["vegetation"], aoi),
            "trees_fraction": class_fraction(masks["trees"], aoi),
            "grass_fraction": class_fraction(masks["grass"], aoi),
            "s2_image_count_before_cloud_filter": s2_before_cloud.size(),
            "s2_image_count_after_cloud_filter": s2_after_cloud.size(),
            "dynamic_world_image_count": dynamic_world.size(),
            "dynamic_world_probability_threshold": DYNAMIC_WORLD_PROBABILITY_THRESHOLD,
            "export_description": EXPORT_DESCRIPTION,
        },
    )


def create_export_task() -> ee.batch.Task:
    return ee.batch.Export.table.toDrive(
        collection=ee.FeatureCollection([build_summary_feature()]),
        description=EXPORT_DESCRIPTION,
        folder=DRIVE_FOLDER,
        fileNamePrefix=FILE_PREFIX,
        fileFormat="CSV",
        selectors=EXPORT_SELECTORS,
    )


def main() -> int:
    logging.basicConfig(level=logging.INFO, format="%(levelname)s %(message)s")
    try:
        task = create_export_task()
        task.start()
        LOG.info("Started export task: %s", EXPORT_DESCRIPTION)
        return 0
    except Exception as exc:
        LOG.exception("Failed to start Hong Kong January 2024 land-cover-aware NDVI export.")
        print(f"ERROR: {exc}", file=sys.stderr)
        return 1


if __name__ == "__main__":
    raise SystemExit(main())
