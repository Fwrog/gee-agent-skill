"""{{ script_name }}

Sentinel-1 before/after flood change workflow.
Generated by gee-agent-skill template sentinel1_flood_before_after v0.1.0.
"""

from __future__ import annotations

import logging
import sys

import ee

LOG = logging.getLogger("gee_skill.sentinel1_flood")

DATASET_ID = "{{ dataset_id | default('COPERNICUS/S1_GRD') }}"
BEFORE_START = "{{ before_start }}"
BEFORE_END = "{{ before_end }}"
AFTER_START = "{{ after_start }}"
AFTER_END = "{{ after_end }}"
AOI_ASSET = "{{ aoi_asset }}"
POLARIZATION = "{{ polarization | default('VH') }}"
ORBIT_PASS = "{{ orbit_pass | default('DESCENDING') }}"
SCALE = {{ scale | default(10) }}
CRS = "{{ crs | default('EPSG:4326') }}"
EXPORT_DESCRIPTION = "{{ export_description }}"
DRIVE_FOLDER = "{{ drive_folder }}"
FILE_PREFIX = "{{ file_prefix | default(export_description) }}"
MAX_PIXELS = {{ max_pixels | default(10000000000000) }}


def build_collection(start_date: str, end_date: str) -> ee.ImageCollection:
    aoi = ee.FeatureCollection(AOI_ASSET).geometry()
    return (
        ee.ImageCollection(DATASET_ID)
        .filterDate(start_date, end_date)
        .filterBounds(aoi)
        .filter(ee.Filter.eq("instrumentMode", "IW"))
        .filter(ee.Filter.listContains("transmitterReceiverPolarisation", POLARIZATION))
        .filter(ee.Filter.eq("orbitProperties_pass", ORBIT_PASS))
        .select(POLARIZATION)
    )


def build_flood_change() -> ee.Image:
    aoi = ee.FeatureCollection(AOI_ASSET).geometry()
    before = build_collection(BEFORE_START, BEFORE_END).median().rename("before")
    after = build_collection(AFTER_START, AFTER_END).median().rename("after")
    ratio = after.subtract(before).rename("after_minus_before_db")
    return ratio.clip(aoi).set(
        {
            "before_start": BEFORE_START,
            "before_end": BEFORE_END,
            "after_start": AFTER_START,
            "after_end": AFTER_END,
            "dataset_id": DATASET_ID,
            "polarization": POLARIZATION,
            "orbit_pass": ORBIT_PASS,
        }
    )


def create_export_task() -> ee.batch.Task:
    aoi = ee.FeatureCollection(AOI_ASSET).geometry()
    return ee.batch.Export.image.toDrive(
        image=build_flood_change(),
        description=EXPORT_DESCRIPTION,
        folder=DRIVE_FOLDER,
        fileNamePrefix=FILE_PREFIX,
        region=aoi,
        scale=SCALE,
        crs=CRS,
        fileFormat="GeoTIFF",
        maxPixels=MAX_PIXELS,
    )


def main() -> int:
    logging.basicConfig(level=logging.INFO, format="%(levelname)s %(message)s")
    try:
        task = create_export_task()
        task.start()
        LOG.info("Started Sentinel-1 flood export: %s", EXPORT_DESCRIPTION)
        return 0
    except Exception as exc:
        LOG.exception("Failed to export Sentinel-1 flood change image.")
        print(f"ERROR: {exc}", file=sys.stderr)
        return 1


if __name__ == "__main__":
    raise SystemExit(main())
