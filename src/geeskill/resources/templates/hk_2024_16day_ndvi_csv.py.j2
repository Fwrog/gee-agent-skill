"""{{ script_name }}

Compute 2024 16-day Sentinel-2 NDVI means for Hong Kong and export CSV.
Generated by gee-agent-skill template hk_2024_16day_ndvi_csv v0.3.0.
"""

from __future__ import annotations

import json
import logging
import sys

import ee

from geeskill.hk_ndvi_preflight import (
    HKNDVIPreflightConfig,
    load_boundary_feature_collection,
    run_hk_ndvi_preflight,
)

LOG = logging.getLogger("gee_skill.hk_2024_16day_ndvi")

YEAR = {{ year }}
START_DATE = "{{ date_start }}"
END_DATE = "{{ date_end }}"
AOI_NAME = "{{ aoi_name }}"
AOI_SOURCE = "{{ aoi_source }}"
BOUNDARY_GEOJSON = "{{ boundary_geojson }}"
DATASET_ID = "{{ dataset_id }}"
SCALE = {{ scale }}
CRS = "{{ crs }}"
TILE_SCALE = {{ tile_scale }}
CLOUDY_PIXEL_PERCENTAGE = {{ cloudy_pixel_percentage }}
MAX_PIXELS = {{ max_pixels }}
CADENCE_DAYS = {{ temporal_cadence_days }}
EXPORT_DESCRIPTION = "{{ export_description }}"
DRIVE_FOLDER = "{{ drive_folder }}"
FILE_PREFIX = "{{ file_prefix }}"
PREFLIGHT_MONTHS = {{ preflight_months | default([1, 7]) }}

EXPORT_SELECTORS = [
    "aoi_name",
    "year",
    "period_index",
    "date_start",
    "date_end",
    "temporal_cadence_days",
    "mean_ndvi",
    "image_count_before_cloud_filter",
    "image_count_after_cloud_filter",
    "dataset_id",
    "scale_m",
    "crs",
    "aoi_source",
    "export_description",
]


def build_hong_kong_aoi() -> ee.FeatureCollection:
    return load_boundary_feature_collection(ee, BOUNDARY_GEOJSON)


def build_s2_collection_before_cloud_filter(start: ee.Date, end: ee.Date, aoi: ee.Geometry) -> ee.ImageCollection:
    return ee.ImageCollection(DATASET_ID).filterDate(start, end).filterBounds(aoi)


def build_s2_collection(start: ee.Date, end: ee.Date, aoi: ee.Geometry) -> ee.ImageCollection:
    return build_s2_collection_before_cloud_filter(start, end, aoi).filter(
        ee.Filter.lt("CLOUDY_PIXEL_PERCENTAGE", CLOUDY_PIXEL_PERCENTAGE)
    )


def mask_sentinel2_scl(image: ee.Image) -> ee.Image:
    scl = image.select("SCL")
    valid = (
        scl.neq(0)
        .And(scl.neq(1))
        .And(scl.neq(3))
        .And(scl.neq(7))
        .And(scl.neq(8))
        .And(scl.neq(9))
        .And(scl.neq(10))
        .And(scl.neq(11))
    )
    return image.updateMask(valid)


def add_ndvi(image: ee.Image) -> ee.Image:
    ndvi = image.normalizedDifference(["B8", "B4"]).rename("NDVI")
    return image.addBands(ndvi)


def empty_ndvi_image() -> ee.Image:
    return ee.Image.constant(0).rename("NDVI").updateMask(ee.Image.constant(0))


def build_period_ndvi(start: ee.Date, end: ee.Date, aoi: ee.Geometry) -> ee.Image:
    collection = build_s2_collection(start, end, aoi).map(mask_sentinel2_scl).map(add_ndvi)
    return ee.Image(
        ee.Algorithms.If(
            collection.size().gt(0),
            collection.select("NDVI").mean().rename("NDVI"),
            empty_ndvi_image(),
        )
    )


def preflight_anchor_months() -> list[dict]:
    reports = []
    for month in PREFLIGHT_MONTHS:
        report = run_hk_ndvi_preflight(
            HKNDVIPreflightConfig(
                project=None,
                year=YEAR,
                month=int(month),
                scope="hong-kong",
                district=None,
                dataset_id=DATASET_ID,
                boundary_geojson=BOUNDARY_GEOJSON,
                scale=SCALE,
                crs=CRS,
                cloudy_pixel_percentage=CLOUDY_PIXEL_PERCENTAGE,
                tile_scale=TILE_SCALE,
            )
        )
        reports.append(report)
    failed = [report for report in reports if not report.get("ok")]
    if failed:
        raise RuntimeError(
            "Preflight failed before export: "
            + json.dumps(failed[0].get("critical_error"), ensure_ascii=False)
        )
    return reports


def build_period_feature(period_index_value, aoi: ee.Geometry) -> ee.Feature:
    period_index = ee.Number(period_index_value).toInt()
    start = ee.Date(START_DATE).advance(period_index.multiply(CADENCE_DAYS), "day")
    raw_end = start.advance(CADENCE_DAYS, "day")
    final_end = ee.Date(END_DATE)
    end = ee.Date(ee.Algorithms.If(raw_end.millis().gt(final_end.millis()), final_end, raw_end))
    before_cloud = build_s2_collection_before_cloud_filter(start, end, aoi)
    after_cloud = build_s2_collection(start, end, aoi)
    ndvi = build_period_ndvi(start, end, aoi)
    mean_ndvi = ndvi.reduceRegion(
        reducer=ee.Reducer.mean(),
        geometry=aoi,
        scale=SCALE,
        crs=CRS,
        bestEffort=True,
        maxPixels=MAX_PIXELS,
        tileScale=TILE_SCALE,
    ).get("NDVI")
    return ee.Feature(
        None,
        {
            "aoi_name": AOI_NAME,
            "year": YEAR,
            "period_index": period_index.add(1),
            "date_start": start.format("YYYY-MM-dd"),
            "date_end": end.format("YYYY-MM-dd"),
            "temporal_cadence_days": CADENCE_DAYS,
            "mean_ndvi": mean_ndvi,
            "image_count_before_cloud_filter": before_cloud.size(),
            "image_count_after_cloud_filter": after_cloud.size(),
            "dataset_id": DATASET_ID,
            "scale_m": SCALE,
            "crs": CRS,
            "aoi_source": AOI_SOURCE,
            "export_description": EXPORT_DESCRIPTION,
        },
    )


def build_16day_statistics() -> ee.FeatureCollection:
    preflight_anchor_months()
    districts = build_hong_kong_aoi()
    aoi = districts.geometry()
    days = ee.Date(END_DATE).difference(ee.Date(START_DATE), "day")
    period_count = days.divide(CADENCE_DAYS).ceil().toInt()
    period_indexes = ee.List.sequence(0, period_count.subtract(1))
    return ee.FeatureCollection(period_indexes.map(lambda index: build_period_feature(index, aoi)))


def create_export_task() -> ee.batch.Task:
    return ee.batch.Export.table.toDrive(
        collection=build_16day_statistics(),
        description=EXPORT_DESCRIPTION,
        folder=DRIVE_FOLDER,
        fileNamePrefix=FILE_PREFIX,
        fileFormat="CSV",
        selectors=EXPORT_SELECTORS,
    )


def main() -> int:
    logging.basicConfig(level=logging.INFO, format="%(levelname)s %(message)s")
    try:
        task = create_export_task()
        task.start()
        LOG.info("Started export task: %s", EXPORT_DESCRIPTION)
        LOG.info("Monitor with gee-skill monitor-exports --project <project-id>")
        return 0
    except Exception as exc:
        LOG.exception("Failed to start Hong Kong 2024 16-day NDVI export.")
        print(f"ERROR: {exc}", file=sys.stderr)
        return 1


if __name__ == "__main__":
    raise SystemExit(main())

