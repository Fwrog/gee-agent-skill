"""{{ script_name }}

Summarize Dynamic World land-cover labels over an AOI and export a CSV.
Generated by gee-agent-skill template dynamic_world_landcover_summary v0.1.0.
"""

from __future__ import annotations

import logging
import sys

import ee

LOG = logging.getLogger("gee_skill.dynamic_world_landcover_summary")

DATASET_ID = "{{ dataset_id }}"
START_DATE = "{{ date_start }}"
END_DATE = "{{ date_end }}"
AOI_NAME = "{{ aoi_name }}"
AOI_ASSET = "{{ aoi_asset }}"
SCALE = {{ scale }}
CRS = "{{ crs }}"
TILE_SCALE = {{ tile_scale | default(4) }}
EXPORT_DESCRIPTION = "{{ export_description }}"
DRIVE_FOLDER = "{{ drive_folder }}"
FILE_PREFIX = "{{ file_prefix | default(export_description) }}"
MAX_PIXELS = {{ max_pixels | default(10000000000000) }}
EXPORT_SELECTORS = [{% for field in output_schema %}"{{ field }}"{% if not loop.last %}, {% endif %}{% endfor %}]

CLASS_NAMES = [
    "water",
    "trees",
    "grass",
    "flooded_vegetation",
    "crops",
    "shrub_and_scrub",
    "built",
    "bare",
    "snow_and_ice",
]


def build_collection() -> ee.ImageCollection:
    aoi = ee.FeatureCollection(AOI_ASSET).geometry()
    return ee.ImageCollection(DATASET_ID).filterDate(START_DATE, END_DATE).filterBounds(aoi)


def build_label_image() -> ee.Image:
    aoi = ee.FeatureCollection(AOI_ASSET).geometry()
    return build_collection().select("label").mode().rename("label").clip(aoi)


def build_statistics() -> ee.FeatureCollection:
    aoi = ee.FeatureCollection(AOI_ASSET).geometry()
    label = build_label_image()
    total_area = ee.Image.pixelArea().reduceRegion(
        reducer=ee.Reducer.sum(),
        geometry=aoi,
        scale=SCALE,
        crs=CRS,
        tileScale=TILE_SCALE,
        maxPixels=MAX_PIXELS,
    ).get("area")

    def class_feature(class_id: ee.Number) -> ee.Feature:
        class_id = ee.Number(class_id)
        area = ee.Image.pixelArea().updateMask(label.eq(class_id)).reduceRegion(
            reducer=ee.Reducer.sum(),
            geometry=aoi,
            scale=SCALE,
            crs=CRS,
            tileScale=TILE_SCALE,
            maxPixels=MAX_PIXELS,
        ).get("area")
        area_number = ee.Number(area)
        return ee.Feature(
            None,
            {
                "aoi_name": AOI_NAME,
                "date_start": START_DATE,
                "date_end": END_DATE,
                "class_id": class_id,
                "class_label": ee.List(CLASS_NAMES).get(class_id),
                "area_m2": area_number,
                "fraction": area_number.divide(ee.Number(total_area)),
                "dataset_id": DATASET_ID,
                "scale_m": SCALE,
                "crs": CRS,
                "export_description": EXPORT_DESCRIPTION,
            },
        )

    return ee.FeatureCollection(ee.List.sequence(0, 8).map(class_feature))


def create_export_task() -> ee.batch.Task:
    return ee.batch.Export.table.toDrive(
        collection=build_statistics(),
        description=EXPORT_DESCRIPTION,
        folder=DRIVE_FOLDER,
        fileNamePrefix=FILE_PREFIX,
        fileFormat="CSV",
        selectors=EXPORT_SELECTORS,
    )


def main() -> int:
    logging.basicConfig(level=logging.INFO, format="%(levelname)s %(message)s")
    try:
        task = create_export_task()
        task.start()
        LOG.info("Started Dynamic World land-cover summary export: %s", EXPORT_DESCRIPTION)
        return 0
    except Exception as exc:
        LOG.exception("Failed to export Dynamic World land-cover summary.")
        print(f"ERROR: {exc}", file=sys.stderr)
        return 1


if __name__ == "__main__":
    raise SystemExit(main())
