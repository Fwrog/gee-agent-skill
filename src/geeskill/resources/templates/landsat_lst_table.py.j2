"""{{ script_name }}

Compute Landsat Collection 2 Level-2 land surface temperature statistics and export CSV.
Generated by gee-agent-skill template landsat_lst_table v0.1.0.
"""

from __future__ import annotations

import logging
import sys

import ee

LOG = logging.getLogger("gee_skill.landsat_lst_table")

DATASET_ID = "{{ dataset_id }}"
START_DATE = "{{ date_start }}"
END_DATE = "{{ date_end }}"
AOI_NAME = "{{ aoi_name }}"
AOI_ASSET = "{{ aoi_asset }}"
SCALE = {{ scale }}
CRS = "{{ crs }}"
TILE_SCALE = {{ tile_scale | default(4) }}
EXPORT_DESCRIPTION = "{{ export_description }}"
DRIVE_FOLDER = "{{ drive_folder }}"
FILE_PREFIX = "{{ file_prefix | default(export_description) }}"
MAX_PIXELS = {{ max_pixels | default(10000000000000) }}
EXPORT_SELECTORS = [{% for field in output_schema %}"{{ field }}"{% if not loop.last %}, {% endif %}{% endfor %}]


def mask_landsat_l2(image: ee.Image) -> ee.Image:
    qa = image.select("QA_PIXEL")
    clear = (
        qa.bitwiseAnd(1 << 0)
        .eq(0)
        .And(qa.bitwiseAnd(1 << 1).eq(0))
        .And(qa.bitwiseAnd(1 << 2).eq(0))
        .And(qa.bitwiseAnd(1 << 3).eq(0))
        .And(qa.bitwiseAnd(1 << 4).eq(0))
        .And(qa.bitwiseAnd(1 << 5).eq(0))
    )
    return image.updateMask(clear)


def add_lst_celsius(image: ee.Image) -> ee.Image:
    lst_kelvin = image.select("ST_B10").multiply(0.00341802).add(149.0)
    lst_c = lst_kelvin.subtract(273.15).rename("LST_C")
    return image.addBands(lst_c)


def build_collection() -> ee.ImageCollection:
    aoi = ee.FeatureCollection(AOI_ASSET).geometry()
    return (
        ee.ImageCollection(DATASET_ID)
        .filterDate(START_DATE, END_DATE)
        .filterBounds(aoi)
        .map(mask_landsat_l2)
        .map(add_lst_celsius)
    )


def build_lst_image() -> ee.Image:
    return build_collection().select("LST_C").median().rename("LST_C")


def build_statistics() -> ee.FeatureCollection:
    aoi = ee.FeatureCollection(AOI_ASSET).geometry()
    collection = build_collection()
    stats = build_lst_image().clip(aoi).reduceRegion(
        reducer=ee.Reducer.mean(),
        geometry=aoi,
        scale=SCALE,
        crs=CRS,
        tileScale=TILE_SCALE,
        maxPixels=MAX_PIXELS,
    )
    feature = ee.Feature(
        None,
        {
            "aoi_name": AOI_NAME,
            "date_start": START_DATE,
            "date_end": END_DATE,
            "mean_lst_c": stats.get("LST_C"),
            "image_count": collection.size(),
            "dataset_id": DATASET_ID,
            "scale_m": SCALE,
            "crs": CRS,
            "export_description": EXPORT_DESCRIPTION,
        },
    )
    return ee.FeatureCollection([feature])


def create_export_task() -> ee.batch.Task:
    return ee.batch.Export.table.toDrive(
        collection=build_statistics(),
        description=EXPORT_DESCRIPTION,
        folder=DRIVE_FOLDER,
        fileNamePrefix=FILE_PREFIX,
        fileFormat="CSV",
        selectors=EXPORT_SELECTORS,
    )


def main() -> int:
    logging.basicConfig(level=logging.INFO, format="%(levelname)s %(message)s")
    try:
        task = create_export_task()
        task.start()
        LOG.info("Started Landsat LST table export: %s", EXPORT_DESCRIPTION)
        return 0
    except Exception as exc:
        LOG.exception("Failed to export Landsat LST table.")
        print(f"ERROR: {exc}", file=sys.stderr)
        return 1


if __name__ == "__main__":
    raise SystemExit(main())

