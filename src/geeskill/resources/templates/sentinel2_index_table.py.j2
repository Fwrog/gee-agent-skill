"""{{ script_name }}

Create a Sentinel-2 optical index summary table and export it as CSV.
Generated by gee-agent-skill template sentinel2_index_table v0.1.0.
"""

from __future__ import annotations

import logging
import sys

import ee

LOG = logging.getLogger("gee_skill.sentinel2_index_table")

DATASET_ID = "{{ dataset_id }}"
START_DATE = "{{ date_start }}"
END_DATE = "{{ date_end }}"
AOI_NAME = "{{ aoi_name }}"
AOI_ASSET = "{{ aoi_asset }}"
INDEX_NAME = "{{ index_name }}"
INDEX_BANDS = [{% for band in index_bands %}"{{ band }}"{% if not loop.last %}, {% endif %}{% endfor %}]
INDEX_OUTPUT_FIELD = "{{ index_output_field }}"
SCALE = {{ scale }}
CRS = "{{ crs }}"
TILE_SCALE = {{ tile_scale | default(4) }}
CLOUDY_PIXEL_PERCENTAGE = {{ cloudy_pixel_percentage | default(80) }}
EXPORT_DESCRIPTION = "{{ export_description }}"
DRIVE_FOLDER = "{{ drive_folder }}"
FILE_PREFIX = "{{ file_prefix | default(export_description) }}"
MAX_PIXELS = {{ max_pixels | default(10000000000000) }}
EXPORT_SELECTORS = [{% for field in output_schema %}"{{ field }}"{% if not loop.last %}, {% endif %}{% endfor %}]


def mask_sentinel2_scl(image: ee.Image) -> ee.Image:
    scl = image.select("SCL")
    valid = (
        scl.neq(0)
        .And(scl.neq(1))
        .And(scl.neq(3))
        .And(scl.neq(7))
        .And(scl.neq(8))
        .And(scl.neq(9))
        .And(scl.neq(10))
        .And(scl.neq(11))
    )
    return image.updateMask(valid)


def add_index(image: ee.Image) -> ee.Image:
    {% if index_expression is defined and index_expression %}
    index = image.expression(
        "{{ index_expression }}",
        {
            {% for name, band in expression_bands.items() %}
            "{{ name }}": image.select("{{ band }}"){% if not loop.last %},{% endif %}
            {% endfor %}
        },
    ).rename(INDEX_NAME)
    return image.addBands(index)
    {% else %}
    return image.addBands(image.normalizedDifference(INDEX_BANDS).rename(INDEX_NAME))
    {% endif %}


def build_collection() -> ee.ImageCollection:
    aoi = ee.FeatureCollection(AOI_ASSET).geometry()
    return (
        ee.ImageCollection(DATASET_ID)
        .filterDate(START_DATE, END_DATE)
        .filterBounds(aoi)
        .filter(ee.Filter.lt("CLOUDY_PIXEL_PERCENTAGE", CLOUDY_PIXEL_PERCENTAGE))
        .map(mask_sentinel2_scl)
        .map(add_index)
    )


def build_index_image() -> ee.Image:
    return build_collection().select(INDEX_NAME).median().rename(INDEX_NAME)


def build_statistics() -> ee.FeatureCollection:
    aoi = ee.FeatureCollection(AOI_ASSET).geometry()
    collection = build_collection()
    image = build_index_image().clip(aoi)
    stats = image.reduceRegion(
        reducer=ee.Reducer.mean(),
        geometry=aoi,
        scale=SCALE,
        crs=CRS,
        tileScale=TILE_SCALE,
        maxPixels=MAX_PIXELS,
    )
    feature = ee.Feature(
        None,
        {
            "aoi_name": AOI_NAME,
            "date_start": START_DATE,
            "date_end": END_DATE,
            "metric": INDEX_NAME,
            INDEX_OUTPUT_FIELD: stats.get(INDEX_NAME),
            "image_count": collection.size(),
            "dataset_id": DATASET_ID,
            "scale_m": SCALE,
            "crs": CRS,
            "export_description": EXPORT_DESCRIPTION,
        },
    )
    return ee.FeatureCollection([feature])


def create_export_task() -> ee.batch.Task:
    return ee.batch.Export.table.toDrive(
        collection=build_statistics(),
        description=EXPORT_DESCRIPTION,
        folder=DRIVE_FOLDER,
        fileNamePrefix=FILE_PREFIX,
        fileFormat="CSV",
        selectors=EXPORT_SELECTORS,
    )


def main() -> int:
    logging.basicConfig(level=logging.INFO, format="%(levelname)s %(message)s")
    try:
        task = create_export_task()
        task.start()
        LOG.info("Started Sentinel-2 %s table export: %s", INDEX_NAME, EXPORT_DESCRIPTION)
        return 0
    except Exception as exc:
        LOG.exception("Failed to export Sentinel-2 optical index table.")
        print(f"ERROR: {exc}", file=sys.stderr)
        return 1


if __name__ == "__main__":
    raise SystemExit(main())
