"""{{ script_name }}

Compute monthly Sentinel-2 NDVI means for Hong Kong districts and export CSV.
Generated by gee-agent-skill template hk_district_monthly_ndvi v0.1.0.
"""

from __future__ import annotations

import logging
import sys

import ee

LOG = logging.getLogger("gee_skill.hk_monthly_ndvi")

YEAR = {{ year }}
START_DATE = "{{ year }}-01-01"
END_DATE = "{{ year + 1 }}-01-01"
DATASET_ID = "{{ dataset_id }}"
ADMIN_COLLECTION = "{{ admin_collection }}"
ADMIN0_NAME = "{{ admin0_name }}"
ADMIN0_PROPERTY = "{{ admin0_property | default('ADM0_NAME') }}"
DISTRICT_PROPERTY = "{{ district_property | default('ADM2_NAME') }}"
SCALE = {{ scale }}
CRS = "{{ crs }}"
TILE_SCALE = {{ tile_scale | default(4) }}
EXPORT_DESCRIPTION = "{{ export_description }}"
DRIVE_FOLDER = "{{ drive_folder }}"
FILE_PREFIX = "{{ file_prefix | default(export_description) }}"
MAX_PIXELS = {{ max_pixels | default(10000000000000) }}


def mask_sentinel2_scl(image: ee.Image) -> ee.Image:
    """Mask invalid Sentinel-2 pixels using the SCL scene classification band."""
    scl = image.select("SCL")
    valid = (
        scl.neq(0)
        .And(scl.neq(1))
        .And(scl.neq(3))
        .And(scl.neq(7))
        .And(scl.neq(8))
        .And(scl.neq(9))
        .And(scl.neq(10))
        .And(scl.neq(11))
    )
    return image.updateMask(valid)


def add_ndvi(image: ee.Image) -> ee.Image:
    ndvi = image.normalizedDifference(["B8", "B4"]).rename("NDVI")
    return image.addBands(ndvi)


def build_districts() -> ee.FeatureCollection:
    districts = ee.FeatureCollection(ADMIN_COLLECTION).filter(
        ee.Filter.eq(ADMIN0_PROPERTY, ADMIN0_NAME)
    )
    return districts


def build_monthly_statistics() -> ee.FeatureCollection:
    districts = build_districts()
    aoi = districts.geometry()
    months = ee.List.sequence(1, 12)

    def month_stats(month_value):
        month = ee.Number(month_value).toInt()
        start = ee.Date.fromYMD(YEAR, month, 1)
        end = start.advance(1, "month")
        collection = (
            ee.ImageCollection(DATASET_ID)
            .filterDate(start, end)
            .filterBounds(aoi)
            .filter(ee.Filter.lt("CLOUDY_PIXEL_PERCENTAGE", {{ cloudy_pixel_percentage | default(80) }}))
            .map(mask_sentinel2_scl)
            .map(add_ndvi)
        )
        monthly_ndvi = (
            collection.select("NDVI")
            .mean()
            .rename("mean_ndvi")
            .set("year", YEAR)
            .set("month", month)
            .set("image_count", collection.size())
        )
        stats = monthly_ndvi.reduceRegions(
            collection=districts,
            reducer=ee.Reducer.mean(),
            scale=SCALE,
            crs=CRS,
            tileScale=TILE_SCALE,
        )

        def annotate(feature):
            return feature.set(
                {
                    "year": YEAR,
                    "month": month,
                    "date_start": start.format("YYYY-MM-dd"),
                    "date_end": end.format("YYYY-MM-dd"),
                    "dataset_id": DATASET_ID,
                    "scale_m": SCALE,
                    "crs": CRS,
                    "image_count": collection.size(),
                    "district_name": feature.get(DISTRICT_PROPERTY),
                }
            )

        return stats.map(annotate)

    return ee.FeatureCollection(months.map(month_stats)).flatten()


def create_export_task() -> ee.batch.Task:
    table = build_monthly_statistics()
    task = ee.batch.Export.table.toDrive(
        collection=table,
        description=EXPORT_DESCRIPTION,
        folder=DRIVE_FOLDER,
        fileNamePrefix=FILE_PREFIX,
        fileFormat="CSV",
        selectors=[
            "district_name",
            DISTRICT_PROPERTY,
            "year",
            "month",
            "date_start",
            "date_end",
            "mean",
            "image_count",
            "dataset_id",
            "scale_m",
            "crs",
        ],
    )
    return task


def main() -> int:
    logging.basicConfig(level=logging.INFO, format="%(levelname)s %(message)s")
    try:
        task = create_export_task()
        task.start()
        LOG.info("Started export task: %s", EXPORT_DESCRIPTION)
        LOG.info("Monitor with gee-skill monitor-exports --project <project-id>")
        return 0
    except Exception as exc:
        LOG.exception(
            "Failed to build or start export. Check authentication, project access, "
            "dataset availability, AOI filters, quotas, and export permissions."
        )
        print(f"ERROR: {exc}", file=sys.stderr)
        return 1


if __name__ == "__main__":
    raise SystemExit(main())

