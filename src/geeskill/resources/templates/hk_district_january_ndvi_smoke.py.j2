"""{{ script_name }}

Small live smoke test: one Hong Kong district, one month, Sentinel-2 NDVI mean CSV export.
Generated by gee-agent-skill template hk_district_january_ndvi_smoke v0.1.0.
"""

from __future__ import annotations

import logging
import sys

import ee

LOG = logging.getLogger("gee_skill.hk_january_ndvi_smoke")

YEAR = {{ year | default(2024) }}
SMOKE_MONTH = {{ smoke_month }}
SMOKE_REGION = "{{ smoke_region }}"
DATASET_ID = "{{ dataset_id | default('COPERNICUS/S2_SR_HARMONIZED') }}"
ADMIN_COLLECTION = "{{ admin_collection | default('FAO/GAUL/2015/level2') }}"
ADMIN0_NAME = "{{ admin0_name | default('Hong Kong') }}"
ADMIN0_PROPERTY = "{{ admin0_property | default('ADM0_NAME') }}"
DISTRICT_PROPERTY = "{{ district_property | default('ADM2_NAME') }}"
SCALE = {{ scale | default(10) }}
CRS = "{{ crs | default('EPSG:4326') }}"
TILE_SCALE = {{ tile_scale | default(4) }}
EXPORT_DESCRIPTION = "{{ export_description }}"
DRIVE_FOLDER = "{{ drive_folder }}"
FILE_PREFIX = "{{ file_prefix | default(export_description) }}"


def mask_sentinel2_scl(image: ee.Image) -> ee.Image:
    scl = image.select("SCL")
    valid = (
        scl.neq(0)
        .And(scl.neq(1))
        .And(scl.neq(3))
        .And(scl.neq(7))
        .And(scl.neq(8))
        .And(scl.neq(9))
        .And(scl.neq(10))
        .And(scl.neq(11))
    )
    return image.updateMask(valid)


def add_ndvi(image: ee.Image) -> ee.Image:
    ndvi = image.normalizedDifference(["B8", "B4"]).rename("NDVI")
    return image.addBands(ndvi)


def build_region() -> ee.FeatureCollection:
    return (
        ee.FeatureCollection(ADMIN_COLLECTION)
        .filter(ee.Filter.eq(ADMIN0_PROPERTY, ADMIN0_NAME))
        .filter(ee.Filter.eq(DISTRICT_PROPERTY, SMOKE_REGION))
    )


def build_statistics() -> ee.FeatureCollection:
    region = build_region()
    aoi = region.geometry()
    start = ee.Date.fromYMD(YEAR, SMOKE_MONTH, 1)
    end = start.advance(1, "month")
    collection = (
        ee.ImageCollection(DATASET_ID)
        .filterDate(start, end)
        .filterBounds(aoi)
        .filter(ee.Filter.lt("CLOUDY_PIXEL_PERCENTAGE", {{ cloudy_pixel_percentage | default(80) }}))
        .map(mask_sentinel2_scl)
        .map(add_ndvi)
    )
    monthly_ndvi = collection.select("NDVI").mean().rename("mean_ndvi")
    stats = monthly_ndvi.reduceRegions(
        collection=region,
        reducer=ee.Reducer.mean(),
        scale=SCALE,
        crs=CRS,
        tileScale=TILE_SCALE,
    )

    def annotate(feature):
        return feature.set(
            {
                "district_name": feature.get(DISTRICT_PROPERTY),
                "year": YEAR,
                "month": SMOKE_MONTH,
                "date_start": start.format("YYYY-MM-dd"),
                "date_end": end.format("YYYY-MM-dd"),
                "dataset_id": DATASET_ID,
                "scale_m": SCALE,
                "crs": CRS,
                "image_count": collection.size(),
            }
        )

    return stats.map(annotate)


def create_export_task() -> ee.batch.Task:
    return ee.batch.Export.table.toDrive(
        collection=build_statistics(),
        description=EXPORT_DESCRIPTION,
        folder=DRIVE_FOLDER,
        fileNamePrefix=FILE_PREFIX,
        fileFormat="CSV",
        selectors=[
            "district_name",
            DISTRICT_PROPERTY,
            "year",
            "month",
            "date_start",
            "date_end",
            "mean",
            "image_count",
            "dataset_id",
            "scale_m",
            "crs",
        ],
    )


def main() -> int:
    logging.basicConfig(level=logging.INFO, format="%(levelname)s %(message)s")
    try:
        task = create_export_task()
        task.start()
        LOG.info("Started smoke export task: %s", EXPORT_DESCRIPTION)
        return 0
    except Exception as exc:
        LOG.exception("Failed to start live smoke export.")
        print(f"ERROR: {exc}", file=sys.stderr)
        return 1


if __name__ == "__main__":
    raise SystemExit(main())

